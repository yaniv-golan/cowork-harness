{
  "$ref": "#/definitions/CoworkHarnessScenario",
  "definitions": {
    "CoworkHarnessScenario": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "default": ""
        },
        "baseline": {
          "type": "string",
          "default": "latest"
        },
        "session": {
          "type": "string",
          "default": "(inline)"
        },
        "fidelity": {
          "type": "string",
          "enum": [
            "protocol",
            "container",
            "microvm",
            "hostloop",
            "cowork"
          ],
          "default": "container"
        },
        "prompt": {
          "type": "string"
        },
        "answers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "when_question": {
                "type": "string"
              },
              "choose": {
                "type": "string"
              },
              "when_tool": {
                "type": "string"
              },
              "decide": {
                "type": "string",
                "enum": [
                  "allow",
                  "deny"
                ]
              },
              "allow_if": {
                "type": "string"
              },
              "else": {
                "type": "string",
                "enum": [
                  "allow",
                  "deny"
                ]
              },
              "grant": {
                "type": "string",
                "enum": [
                  "once",
                  "domain"
                ]
              }
            },
            "additionalProperties": false
          },
          "default": []
        },
        "on_unanswered": {
          "type": "string",
          "enum": [
            "fail",
            "prompt",
            "llm",
            "first"
          ]
        },
        "expect_denied": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "assert": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "transcript_contains": {
                "type": "string"
              },
              "transcript_not_contains": {
                "type": "string"
              },
              "transcript_matches": {
                "type": "string"
              },
              "transcript_not_matches": {
                "type": "string"
              },
              "file_exists": {
                "type": "string"
              },
              "user_visible_artifact": {
                "type": "string"
              },
              "tool_called": {
                "type": "string"
              },
              "tool_not_called": {
                "type": "string"
              },
              "subagent_tool_used": {
                "type": "string"
              },
              "subagent_tool_absent": {
                "type": "string"
              },
              "subagent_dispatched": {
                "type": "string"
              },
              "subagent_declared_but_unused": {
                "type": "string"
              },
              "dispatch_count_max": {
                "type": "number"
              },
              "egress_denied": {
                "type": "string"
              },
              "egress_allowed": {
                "type": "string"
              },
              "no_delete_in_outputs": {
                "type": "boolean"
              },
              "self_heal_ran": {
                "type": "boolean"
              },
              "transcript_no_host_path": {
                "type": "boolean"
              },
              "question_asked": {
                "type": "string"
              },
              "questions_count_max": {
                "type": "number"
              },
              "gate_answers_delivered": {
                "type": "boolean"
              },
              "result": {
                "type": "string",
                "enum": [
                  "success",
                  "error"
                ]
              },
              "replay_protocol_fidelity": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "default": []
        }
      },
      "required": [
        "prompt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "cowork-harness scenario YAML — prompt + scripted answers + assert:. See docs/scenario.md."
}
